{["/_FILES_.tbfs"] = {content = "{[\"/lfrtBin\"] = {date = 0, type = \"dir\"}, [\"/lfrtBin/lfjnvm.lfar\"] = {content = \"{[\\\"/VM.lua\\\"] = {content = \\\"local json = class:getAPI(\\\\\\\"json\\\\\\\", 0)\\\\nlocal vm = {}\\\\nvm.vars = {}\\\\nvm.i = 0\\\\nvm.method = {\\\\n\\\\9setVar=function(self, output, value)\\\\n\\\\9\\\\9self.vars[tostring(output)] = value\\\\n\\\\9end,\\\\n\\\\9concatVar=function(self, output, OP, x, y, z)\\\\n\\\\9\\\\9out = \\\\\\\"\\\\\\\"\\\\n\\\\9\\\\9local op = tonumber(OP)\\\\n\\\\9\\\\9if op == 0 then\\\\n\\\\9\\\\9\\\\9out = x .. y\\\\n\\\\9\\\\9elseif op == 1 then\\\\n\\\\9\\\\9\\\\n\\\\9\\\\9end\\\\n\\\\9\\\\9self.vars[output] = out\\\\n\\\\9end,\\\\n\\\\9Goto = function(self, idx)\\\\n\\\\9\\\\9self.i = idx - 1\\\\n\\\\9end,\\\\n\\\\9NOFUNC = function()\\\\n\\\\9\\\\9--literally do nothing\\\\n\\\\9end\\\\n}\\\\nvm.code = {}\\\\nfunction vm:decode(str)\\\\n\\\\9for i, v in ipairs(str:split(\\\\\\\"\\\\\\\\n\\\\\\\")) do\\\\n\\\\9\\\\9if v == \\\\\\\"\\\\\\\" then return end\\\\n\\\\9\\\\9log(v)\\\\n\\\\9\\\\9self.code[i] = (self.code[i] or {})\\\\n\\\\9\\\\9local a = json.decode(v)\\\\n\\\\9\\\\9log(a.method, a.args)\\\\n\\\\9\\\\9self.code[i] = {a.method, table.unpack(json.decode(a.args))}\\\\n\\\\9end\\\\nend\\\\nfunction vm:reset()\\\\n\\\\9self.i=0\\\\n\\\\9self.code={}\\\\nend\\\\nfunction vm:start()\\\\n\\\\9self.i = 1\\\\n\\\\9while self.i <= #self.code do\\\\n\\\\9\\\\9local a = table.pack(table.unpack(self.code[self.i], 2, #self.code[self.i]))\\\\n\\\\9\\\\9local b = {}\\\\n\\\\9\\\\9for _, v in ipairs(a) do\\\\n\\\\9\\\\9\\\\9if string.sub(v, 1, 1) == \\\\\\\"#\\\\\\\" then\\\\n\\\\9\\\\9\\\\9\\\\9table.insert(b, self.vars[string.sub(v, 2, -1)])\\\\n\\\\9\\\\9\\\\9else\\\\n\\\\9\\\\9\\\\9\\\\9table.insert(b, string.sub(v, 2, -1))\\\\n\\\\9\\\\9\\\\9end\\\\n\\\\9\\\\9end\\\\n\\\\9\\\\9log(table.unpack(self.code[self.i]))\\\\n\\\\9\\\\9log(pcall(self.method[self.code[self.i][1]], self, table.unpack(b)))\\\\n\\\\9\\\\9self.i = self.i + 1\\\\n\\\\9\\\\9aStep()\\\\n\\\\9end\\\\n\\\\9self.i = 0\\\\nend\\\\nfunction vm:run(str)\\\\n\\\\9self:reset()\\\\n\\\\9self:decode(str)\\\\n\\\\9self:start()\\\\nend\\\\nreturn vm\\\\n\\\", date = 0, type = \\\"file\\\"}, [\\\"/_MAIN_.lua\\\"] = {content = \\\"local args = {...}\\\\nlocal json = class:getAPI(\\\\\\\"json\\\\\\\", 0)\\\\nlocal fs = class:getAPI(\\\\\\\"filesystem\\\\\\\", 1)\\\\nlocal term = class:getAPI(\\\\\\\"term\\\\\\\", 1)\\\\nlocal args = {...}\\\\nif args[1] == '-c' then\\\\n\\\\9local output = \\\\\\\"\\\\\\\"\\\\n\\\\9local ok = true\\\\n\\\\9local data = fs.readAll(args[2])\\\\n\\\\9local lines = data:split(\\\\\\\"\\\\\\\\n\\\\\\\")\\\\n\\\\9local function line(method, ...)\\\\n\\\\9\\\\9return json.encode({\\\\n\\\\9\\\\9\\\\9method=method or \\\\\\\"NOFUNC\\\\\\\",\\\\n\\\\9\\\\9\\\\9args=json.encode(({...}))\\\\n\\\\9\\\\9}) .. \\\\\\\"\\\\\\\\n\\\\\\\"\\\\n\\\\9end\\\\n\\\\9for i, v in ipairs(data:split(\\\\\\\"\\\\\\\\n\\\\\\\")) do\\\\n\\\\9\\\\9local f, r = load(\\\\\\\"local l = ... \\\\\\\\n return l(\\\\\\\" .. v .. \\\\\\\")\\\\\\\", '=Line' .. i, 't', _ENV)\\\\n\\\\9\\\\9if f == nil and type(r) == \\\\\\\"string\\\\\\\" then\\\\n\\\\9\\\\9\\\\9term.write(\\\\\\\"Error While Compiling: \\\\\\\" .. r ..\\\\\\\"\\\\\\\\n\\\\\\\")\\\\n\\\\9\\\\9\\\\9ok = false\\\\n\\\\9\\\\9\\\\9break\\\\n\\\\9\\\\9else\\\\n\\\\9\\\\9\\\\9local ok, r = pcall(f, line)\\\\n\\\\9\\\\9\\\\9log(ok, r)\\\\n\\\\9\\\\9\\\\9if not ok then\\\\n\\\\9\\\\9\\\\9\\\\9term.write(\\\\\\\"Error While Compiling: \\\\\\\" .. r .. \\\\\\\"\\\\\\\\n\\\\\\\")\\\\n\\\\9\\\\9\\\\9\\\\9ok = false\\\\n\\\\9\\\\9\\\\9\\\\9break\\\\n\\\\9\\\\9\\\\9end\\\\n\\\\9\\\\9\\\\9output = output .. r\\\\n\\\\9\\\\9end\\\\n\\\\9end\\\\n\\\\9term.write(tostring(output))\\\\n\\\\9fs.writeAll(args[3], output)\\\\nelseif args[1] == '-r' then\\\\n\\\\9local f, r = loadfile(lfarP .. \\\\\\\"VM.lua\\\\\\\", \\\\\\\"t\\\\\\\", _ENV)\\\\n\\\\9log(tostring(f), tostring(r))\\\\n\\\\9local ok, vm = pcall(f)\\\\n\\\\9log(ok, vm)\\\\n\\\\9vm.method.print = function(self, value) term.write(value) end \\\\n\\\\9vm.method.input = function(self, output, str)\\\\n\\\\9\\\\9local DN = false\\\\n\\\\9\\\\9term.read(function(inp)\\\\n\\\\9\\\\9\\\\9self.vars[output] = inp\\\\n\\\\9\\\\9\\\\9DN = true\\\\n\\\\9\\\\9end, false, str)\\\\n\\\\9\\\\9repeat aStep() until DN\\\\n\\\\9end\\\\n \\\\9vm:run(fs.readAll(args[2]))\\\\nend\\\\n\\\\9\\\\n\\\\9\\\\9\\\\n\\\", date = 0, type = \\\"file\\\"}}\", date = 0, type = \"file\"}}", date = 0, type = "file"}, ["/_INFO_.lua"] = {content = "{\n    packageID = \"com.luafoxyt.github.io.lfrt-echo-template\",\n    packageName = \"echo\", -- name of youre progeram\n    packageVersion = 000000001, -- version seperated by three the something like 0.0.1 becomes 000000001 1.1.1 is 001001001 and so on, must be a number\n    packageAuthor = \"LuaFoxYT\", -- the author of the package, can be any string\n    packageDescription = \"A template for creating LFPK packages.\", -- a short description of the package, can be any string\n    packageLicense = \"MIT\", -- license of the package, can be any license, but must be a valid SPDX license identifier. See https://spdx.org/licenses/ for a list of valid identifiers.\n    packageDependencies = {\n        --[\"LuaFoxYT/LuaFoxRuntime-Develoupment-Program\"] = {\n        --    version = \"latest\",\n        --    branch = \"main\"\n        --}, -- an example of a dependency\n    },\n    files = { -- package's removable files.\n        [\"/lfrtBin/echo.lfar\"] = true, -- the files that are in the project, true if removable, false if not, the path is relative to a exisiting folder in the comnputer we dont want to delete. the _-_lfrtBin_-_ represents the platforms lfrtBin folder specified by LFPC (LuaFox Platform Core) in linux its $HOME/.config in windows its Users/<User>/%AppData%/roaming\n    },\n}", date = 0, type = "file"}}