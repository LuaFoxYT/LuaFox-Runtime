{["/Data"] = {date = 0, type = "dir"}, ["/Data/bin"] = {date = 0, type = "dir"}, ["/Data/bin/External.lua"] = {content = "--check platform--\nif _PLATFORM[1] == 'linux' then\n\9local str = ''\n\9for i, v in ipairs({...}) do\n\9\9str = str .. string.format(\"%q \", tostring(v))\n\9end\n\9os.execute(str)\nelse\n\9error('cannot run external command: unsupported platform', 0)\nend", date = 0, type = "file"}, ["/Data/bin/python.lua"] = {content = "", date = 0, type = "file"}, ["/Data/bin/tbfs.lua"] = {content = "local args = {...}\nlocal fs = class:getAPI('filesystem', 0)\nlocal tbfs = class:getAPI('tbfs', 0)\nlocal tb = {}\nif args[1] == '-c' then\n\9tbfs.compress(args[2], (args[3] or './out.tbfs'))\nelseif args[1] == '-e' then\n\9tbfs.extract(args[2], (args[3] or './lfar-output/'))\nend", date = 0, type = "file"}, ["/Data/lib"] = {date = 0, type = "dir"}, ["/Data/lib/001-json.lua"] = {content = "class.lfrt.api.api(require('json'), 'TheLuaFox86:json', 0)", date = 0, type = "file"}, ["/_MAIN_.lua"] = {content = "local args = {...}\nlocal csr = {lfarP .. 'Data/bin/', './'}\nlocal function cmdexec(name, ...)\n\9local tb = {}\n\9for _, v in ipairs(csr) do\n\9\9local ok = fs.exists(v .. (name or 'nomedia') .. '.lua')\n\9\9if ok then\n\9\9\9tb = table.pack(pcall(loadfile(v .. name .. '.lua', 't', _ENV), ...))\n\9\9\9break\n\9\9end\n\9end\n\9return table.unpack(tb, 1, #tb)\nend\nlog('lfdev Terminal initialization')\nlog(cmdexec('tbfs', '-e', os.getenv('HOME') .. '/lfdev-save.tbfs', lfarP .. '/Data'))\nlocal term = class:getAPI('lfrt:term', 0)\nterm.write('loading...\\n')\nlocal fs = class:getAPI('lfrt:filesystem', 0)\nfor i=0, 999 do\n\9for _, fn in ipairs(fs.list(lfarP .. 'Data/lib')) do\n\9\9if tonumber(fn:sub(1, 3)) == i then\n\9\9\9log('loading module: ' .. fn)\n\9\9\9local f = fs.open(lfarP .. 'Data/lib/' .. fn, 'r')\n\9\9\9local env = {}\n\9\9\9for k, v in pairs(_ENV) do\n\9\9\9\9env[k] = v\n\9\9\9end\n\n\9\9\9env._G = env\n\9\9\9local ok, r = pcall(load(f:read(\"*all\") .. '\\nreturn class', '=lib', \"t\", env))\n\9\9\9if ok then \n\9\9\9\9_G.class = r\n\9\9\9else\n\9\9\9\9log('module failed to load: ' .. r)\n\9\9\9end\n\9\9\9f:close()\n\9\9end\n\9end\nend\nterm.write('LFDev Terminal (LuaFox Runtime) Alpha1 \\n')\nterm.write(fs.pwd() .. '> ')\nif args[1] then\n\9cmdexec(args[1], table.unpack(args, 2, #args))\nelse\nterm.read(function(txt)\n\9local args = txt:split(' ')\n\9for i=1, #args do\n\9   \9args[i] = args[i]:gsub('\\\\s', ' ')\n\9\9args[i] = args[i]:gsub('\\\\n', '\\n')\n\9end\n\9if args[1] == 'exit' then\n\9\9log(cmdexec('tbfs', '-c', lfarP .. '/Data', os.getenv('HOME') .. '/lfdev-save.tbfs'))\n\9\9return true\n\9elseif args[1] == 'cd' then\n\9\9fs.pwd(args[2])\n    term.write(fs.pwd() .. '> ')\n\9\9return nil\n\9end\n\9cmdexec(table.unpack(args, 1, #args))\n\9 term.write(fs.pwd() .. '> ')\nend, true)\nend", date = 0, type = "file"}, ["/log.txt"] = {content = "creating api: lfrt:term version 0\9\nadded class: lfrt:term of type [api]\9\ncreating api: lfrt:filesystem version 0\9\nadded class: lfrt:filesystem of type [api]\9\ncreating api: lfrt:runtime version 0\9\nadded class: lfrt:runtime of type [api]\9\nfalse\9lfrt:173: attempt to concatenate a nil value (global 'lfarP')\9\n", date = 0, type = "file"}}